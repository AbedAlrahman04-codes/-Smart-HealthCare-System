<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare Center</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Bootstrap RTL -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css">

    <!-- Custom CSS - IMPORTANT ORDER! -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="container">
            <!-- Logo -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <div class="logo-icon">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <div class="logo-text">
                    <div class="logo-title"> HealthCare System </div>
                    <div class="logo-subtitle">نظام الرعاية الصحية الذكي</div>
                </div>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggle" onclick="toggleMobileMenu()">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Navigation Links -->
            <ul class="navbar-nav" id="navbarNav">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i>
                        الرئيسية
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="AIAssistant" asp-action="Index">
                        <i class="fas fa-robot"></i>
                        المساعد الذكي
                    </a>
                </li>

                @{
                    var userRole = Context.Session.GetString("Role");
                    var userId = Context.Session.GetInt32("UserId");
                }

                @if (userId != null)
                {
                    @if (userRole == "Doctor")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Doctor" asp-action="Dashboard">
                                <i class="fas fa-user-md"></i>
                                لوحة التحكم
                            </a>
                        </li>
                    }
                    else if (userRole == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                <i class="fas fa-tachometer-alt"></i>
                                الإدارة
                            </a>
                        </li>
                    }
                    else if (userRole == "Patient")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Patient" asp-action="Dashboard">
                                <i class="fas fa-th-large"></i>
                                لوحة التحكم
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Patient" asp-action="MyAppointments">
                                <i class="fas fa-calendar-check"></i>
                                مواعيدي
                            </a>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MedicalRecord" asp-action="MyRecords">
                                <i class="fas fa-file-medical"></i>
                                سجلاتي الطبية
                            </a>
                        </li>
                        </li>
                    }
                }
            </ul>

            <!-- Actions -->
            <div class="navbar-actions" id="navbarActions">
                @if (userId != null)
                {
                    var fullName = Context.Session.GetString("FullName") ?? "User";
                    var nameWords = fullName.Split(' ');
                    var initials = nameWords.Length >= 2
                    ? nameWords[0].Substring(0, 1) + nameWords[1].Substring(0, 1)
                    : nameWords[0].Substring(0, 1);

                    <div class="user-dropdown" id="userDropdown">
                        <div class="user-trigger" onclick="toggleDropdown()">
                            <div class="user-avatar">@initials</div>
                            <div class="user-info">
                                <p class="user-name">@fullName</p>
                                <p class="user-role">@userRole</p>
                            </div>
                            <i class="fas fa-chevron-down dropdown-icon"></i>
                        </div>
                        <div class="dropdown-menu-custom">
                            @if (userRole == "Patient")
                            {
                                <a class="dropdown-item-custom" asp-controller="Patient" asp-action="Profile">
                                    <i class="fas fa-user"></i>
                                    <span>الملف الشخصي</span>
                                </a>
                            }
                            else
                            {
                                <a class="dropdown-item-custom" asp-controller="Account" asp-action="Profile">
                                    <i class="fas fa-user"></i>
                                    <span>الملف الشخصي</span>
                                </a>
                            }
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item-custom" asp-controller="Account" asp-action="Logout">
                                <i class="fas fa-sign-out-alt"></i>
                                <span>تسجيل الخروج</span>
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a class="btn-navbar btn-login" asp-controller="Account" asp-action="Login">
                        <i class="fas fa-sign-in-alt"></i>
                        تسجيل الدخول
                    </a>
                    <a class="btn-navbar btn-register" asp-controller="Account" asp-action="Register">
                        <i class="fas fa-user-plus"></i>
                        إنشاء حساب
                    </a>
                }
            </div>
        </div>
    </nav>

    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-container">
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-container">
            <div class="alert alert-danger alert-dismissible fade show">
                <i class="fas fa-exclamation-circle"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer-premium">
        <div class="container">
            <div class="row">
                <div class="col-md-4 footer-section">
                    <h5><i class="fas fa-heartbeat"></i> Smart Healthcare</h5>
                    <p style="color: rgba(255, 255, 255, 0.8); line-height: 1.8;">
                        نظام رعاية صحية ذكي يوفر مساعد طبي بالذكاء الاصطناعي لتحليل الأعراض واقتراح العلاج المناسب.
                    </p>
                </div>

                <div class="col-md-4 footer-section">
                    <h5>روابط سريعة</h5>
                    <ul>
                        <li><a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-left"></i> الرئيسية</a></li>
                        <li><a asp-controller="AIAssistant" asp-action="Index"><i class="fas fa-chevron-left"></i> المساعد الذكي</a></li>
                    </ul>
                </div>

                <div class="col-md-4 footer-section">
                    <h5>معلومات التواصل</h5>
                    <ul>
                        <li><i class="fas fa-map-marker-alt"></i> عمان، الأردن</li>
                        <li><i class="fas fa-envelope"></i> info@smarthealthcare.jo</li>
                        <li><i class="fas fa-clock"></i> متاح 24/7</li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <p>&copy; 2025 Smart Healthcare Center. جميع الحقوق محفوظة.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleDropdown() {
            const dropdown = document.getElementById('userDropdown');
            if (dropdown) dropdown.classList.toggle('active');
        }

        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('userDropdown');
            if (dropdown && !dropdown.contains(event.target)) {
                dropdown.classList.remove('active');
            }
        });

        function toggleMobileMenu() {
            const nav = document.getElementById('navbarNav');
            const actions = document.getElementById('navbarActions');
            nav.classList.toggle('active');
            if (actions) actions.classList.toggle('active');
        }

        window.addEventListener('scroll', () => {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
