@model SmartHealthcareSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

<div class="auth-page">
    <div class="auth-container">
        <!-- Side Panel -->
        <div class="auth-side">
            <div class="auth-side-content">
                <div class="auth-side-icon">
                    <i class="fas fa-heartbeat"></i>
                </div>
                <h2>مرحباً بعودتك!</h2>
                <p>نظام رعاية صحية ذكي يوفر لك أفضل الخدمات الطبية</p>

                <ul class="auth-side-features">
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>مساعد طبي ذكي متاح 24/7</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>تحليل الأعراض بالذكاء الاصطناعي</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>اقتراحات علاجية موثوقة</span>
                    </li>
                    <li>
                        <i class="fas fa-check-circle"></i>
                        <span>إدارة المواعيد بسهولة</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Form Side -->
        <div class="auth-form-side">
            <div class="auth-header">
                <div class="auth-logo">
                    <i class="fas fa-user-lock"></i>
                </div>
                <h1>تسجيل الدخول</h1>
                <p>أدخل بياناتك للوصول إلى حسابك</p>
            </div>

            <form asp-controller="Account" asp-action="Login" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

                <!-- Username -->
                <div class="form-group">
                    <label asp-for="Username" class="form-label">
                        <span class="required">*</span>
                        اسم المستخدم
                    </label>
                    <div class="input-wrapper">
                        <input asp-for="Username"
                               class="form-control"
                               placeholder="أدخل اسم المستخدم"
                               autocomplete="username" />
                        <i class="fas fa-user input-icon"></i>
                    </div>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label asp-for="Password" class="form-label">
                        <span class="required">*</span>
                        كلمة المرور
                    </label>
                    <div class="input-wrapper">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               placeholder="أدخل كلمة المرور"
                               autocomplete="current-password" />
                        <i class="fas fa-lock input-icon"></i>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Remember Me -->
                <div class="form-check">
                    <input asp-for="RememberMe"
                           type="checkbox"
                           class="form-check-input"
                           id="rememberMe" />
                    <label class="form-check-label" for="rememberMe">
                        تذكرني
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn-auth">
                    <i class="fas fa-sign-in-alt"></i>
                    تسجيل الدخول
                </button>

                <!-- Divider -->
                <div class="auth-divider">
                    <span>أو</span>
                </div>

                <!-- Register Link -->
                <div class="auth-footer">
                    <p>
                        ليس لديك حساب؟
                        <a asp-controller="Account" asp-action="Register">
                            إنشاء حساب جديد
                        </a>
                    </p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Auto-focus on username field
        document.addEventListener('DOMContentLoaded', function() {
            const usernameInput = document.querySelector('input[name="Username"]');
            if (usernameInput) {
                usernameInput.focus();
            }
        });
    </script>
}
