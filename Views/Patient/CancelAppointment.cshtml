@model SmartHealthcareSystem.Models.Appointment

@{
    ViewData["Title"] = "إلغاء الموعد";
}

@section Styles {
    <link rel="stylesheet" href="~/css/appointments.css" />
}

<div class="appointment-details-page">
    <div class="appointment-details-container">
        <!-- Page Header -->
        <div style="background: white; border-radius: 20px; padding: 2rem; margin-bottom: 2rem; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.1); border: 2px solid #FECACA;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div style="display: flex; align-items: center; gap: 1.5rem;">
                    <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; box-shadow: 0 6px 20px rgba(239, 68, 68, 0.3);">
                        <i class="fas fa-times-circle"></i>
                    </div>
                    <div>
                        <h1 style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin: 0 0 0.5rem 0;">
                            إلغاء الموعد
                        </h1>
                        <p style="color: #64748B; font-size: 1.1rem; margin: 0;">
                            هل أنت متأكد من إلغاء هذا الموعد؟
                        </p>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <a href="@Url.Action("AppointmentDetails", "Patient", new { id = Model.AppointmentId })" class="btn btn-secondary">
                        <i class="fas fa-arrow-right"></i>
                        <span>العودة</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Warning Message -->
        <div style="background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%); border-radius: 20px; padding: 2.5rem; margin-bottom: 2rem; border: 3px solid #EF4444; box-shadow: 0 8px 24px rgba(239, 68, 68, 0.2);">
            <div style="display: flex; align-items: center; gap: 1.5rem;">
                <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 2.5rem; flex-shrink: 0; box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div>
                    <h3 style="font-size: 1.8rem; font-weight: 800; color: #991B1B; margin: 0 0 0.5rem 0;">
                        تحذير: عملية الإلغاء نهائية
                    </h3>
                    <p style="color: #7F1D1D; font-size: 1.1rem; line-height: 1.6; margin: 0;">
                        بمجرد إلغاء الموعد، لن تتمكن من استعادته. ستحتاج إلى حجز موعد جديد إذا غيرت رأيك.
                    </p>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
            <!-- Cancel Form -->
            <div style="background: white; border-radius: 20px; padding: 2.5rem; box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1); border: 2px solid #BFDBFE;">
                <!-- Appointment Details to be Cancelled -->
                <div style="background: linear-gradient(135deg, #F8FAFC 0%, #F1F5F9 100%); border-radius: 16px; padding: 2rem; margin-bottom: 2rem; border: 2px solid #E2E8F0;">
                    <h3 style="font-size: 1.5rem; font-weight: 800; color: #0F172A; margin: 0 0 1.5rem 0; padding-bottom: 1rem; border-bottom: 2px solid #E2E8F0;">
                        <i class="fas fa-calendar-times"></i>
                        تفاصيل الموعد المراد إلغاؤه
                    </h3>

                    <div style="display: grid; gap: 1rem;">
                        <!-- Doctor -->
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.3rem; flex-shrink: 0;">
                                <i class="fas fa-user-md"></i>
                            </div>
                            <div>
                                <p style="color: #64748B; font-size: 0.85rem; margin: 0;">الطبيب</p>
                                <h4 style="color: #0F172A; font-size: 1.1rem; font-weight: 800; margin: 0;">
                                    د. @Model.Doctor?.User?.FullName
                                </h4>
                                <p style="color: #3B82F6; font-size: 0.9rem; margin: 0;">
                                    @Model.Doctor?.Specialization
                                </p>
                            </div>
                        </div>

                        <!-- Date & Time -->
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.3rem; flex-shrink: 0;">
                                    <i class="fas fa-calendar"></i>
                                </div>
                                <div>
                                    <p style="color: #64748B; font-size: 0.85rem; margin: 0;">التاريخ</p>
                                    <h4 style="color: #0F172A; font-size: 1.1rem; font-weight: 800; margin: 0;">
                                        @Model.AppointmentDate.ToString("yyyy-MM-dd")
                                    </h4>
                                </div>
                            </div>

                            <div style="display: flex; align-items: center; gap: 1rem;">
                                <div style="width: 50px; height: 50px; background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.3rem; flex-shrink: 0;">
                                    <i class="fas fa-clock"></i>
                                </div>
                                <div>
                                    <p style="color: #64748B; font-size: 0.85rem; margin: 0;">الوقت</p>
                                    <h4 style="color: #0F172A; font-size: 1.1rem; font-weight: 800; margin: 0;">
                                        @Model.AppointmentDate.ToString("hh:mm tt")
                                    </h4>
                                </div>
                            </div>
                        </div>

                        <!-- Reason if exists -->
                        @if (!string.IsNullOrEmpty(Model.Reason))
                        {
                            <div style="background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); border-radius: 12px; padding: 1rem; border-right: 4px solid #F59E0B;">
                                <p style="color: #92400E; font-size: 0.85rem; font-weight: 600; margin: 0 0 0.5rem 0;">
                                    <i class="fas fa-info-circle"></i> سبب الزيارة
                                </p>
                                <p style="color: #78350F; margin: 0;">@Model.Reason</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Cancel Form -->
                <form asp-action="CancelAppointment" asp-controller="Patient" method="post" id="cancelForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.AppointmentId" />

                    <!-- Cancellation Reason -->
                    <div class="form-group">
                        <label class="form-label" for="cancellationReason">
                            <i class="fas fa-comment"></i>
                            سبب الإلغاء (اختياري)
                        </label>
                        <textarea class="form-control"
                                  id="cancellationReason"
                                  name="cancellationReason"
                                  rows="4"
                                  placeholder="اكتب سبب إلغاء الموعد إذا أردت..."></textarea>
                        <small style="color: #64748B; display: block; margin-top: 0.5rem;">
                            <i class="fas fa-info-circle"></i>
                            سيساعدنا ذلك في تحسين خدماتنا
                        </small>
                    </div>

                    <!-- Confirmation Checkbox -->
                    <div style="background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%); border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem; border: 2px solid #EF4444;">
                        <div style="display: flex; align-items: start; gap: 1rem;">
                            <input type="checkbox"
                                   id="confirmCancel"
                                   required
                                   style="width: 24px; height: 24px; margin-top: 0.2rem; cursor: pointer; flex-shrink: 0;" />
                            <label for="confirmCancel" style="color: #991B1B; font-weight: 700; cursor: pointer; line-height: 1.6; margin: 0;">
                                أقر بأنني أفهم أن هذا الإلغاء نهائي ولن أتمكن من استعادة الموعد. سأحتاج إلى حجز موعد جديد في حال غيرت رأيي.
                            </label>
                        </div>
                    </div>

                    <!-- Submit Buttons -->
                    <div style="display: flex; gap: 1rem;">
                        <button type="submit" class="btn btn-danger" style="flex: 1;">
                            <i class="fas fa-times-circle"></i>
                            <span>تأكيد الإلغاء</span>
                        </button>
                        <a href="@Url.Action("AppointmentDetails", "Patient", new { id = Model.AppointmentId })" class="btn btn-secondary" style="flex: 1;">
                            <i class="fas fa-arrow-right"></i>
                            <span>العودة للموعد</span>
                        </a>
                    </div>
                </form>
            </div>

            <!-- Alternative Options Sidebar -->
            <div>
                <!-- Reschedule Instead -->
                <div style="background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%); border-radius: 16px; padding: 2rem; margin-bottom: 1.5rem; border: 2px solid #FCD34D;">
                    <div style="text-align: center; margin-bottom: 1.5rem;">
                        <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; margin: 0 auto 1rem; box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
                            <i class="fas fa-calendar-alt"></i>
                        </div>
                        <h4 style="font-size: 1.3rem; font-weight: 800; color: #92400E; margin: 0 0 0.5rem 0;">
                            هل تريد تغيير الموعد؟
                        </h4>
                        <p style="color: #78350F; font-size: 0.95rem; margin: 0;">
                            يمكنك إعادة جدولة الموعد بدلاً من إلغائه
                        </p>
                    </div>
                    <a href="@Url.Action("RescheduleAppointment", "Patient", new { id = Model.AppointmentId })" class="btn btn-warning" style="width: 100%;">
                        <i class="fas fa-calendar-alt"></i>
                        <span>إعادة جدولة الموعد</span>
                    </a>
                </div>

                <!-- AI Assistant -->
                <div style="background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%); border-radius: 16px; padding: 2rem; border: 2px solid #93C5FD; text-align: center;">
                    <i class="fas fa-robot" style="font-size: 2.5rem; color: #3B82F6; margin-bottom: 1rem;"></i>
                    <h4 style="font-size: 1.2rem; font-weight: 800; color: #1E40AF; margin: 0 0 0.5rem 0;">
                        استشر المساعد الذكي
                    </h4>
                    <p style="color: #1E3A8A; margin: 0 0 1rem 0; font-size: 0.95rem;">
                        تحدث مع المساعد الذكي قبل اتخاذ القرار
                    </p>
                    <a href="@Url.Action("Index", "AIAssistant")" class="btn btn-primary" style="width: 100%;">
                        <i class="fas fa-comments"></i>
                        <span>التحدث مع المساعد</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-group {
        margin-bottom: 2rem;
    }

    .form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        color: #0F172A;
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
    }

        .form-label i {
            color: #3B82F6;
            font-size: 1.2rem;
        }

    .form-control {
        width: 100%;
        padding: 1rem 1.5rem;
        border: 2px solid #E2E8F0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #3B82F6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

    .btn {
        padding: 1rem 2rem;
        border-radius: 12px;
        border: none;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        text-decoration: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .btn-secondary {
        background: linear-gradient(135deg, #F1F5F9 0%, #E2E8F0 100%);
        color: #475569;
    }

    .btn-warning {
        background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
        color: white;
    }

    .btn-danger {
        background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
        color: white;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }
</style>

@section Scripts {
    <script>
        document.getElementById('cancelForm').addEventListener('submit', function(e) {
            if (!confirm('هل أنت متأكد تماماً من رغبتك في إلغاء هذا الموعد؟ هذا القرار نهائي ولا يمكن التراجع عنه.')) {
                e.preventDefault();
            }
        });
    </script>
}
