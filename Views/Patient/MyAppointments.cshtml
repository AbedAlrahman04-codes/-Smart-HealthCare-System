@model List<SmartHealthcareSystem.Models.Appointment>

@{
    ViewData["Title"] = "مواعيدي";
    var currentStatus = ViewBag.CurrentStatus as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/patient.css" />
}

<div class="patient-page">
    <div class="patient-container">
        <!-- Page Header -->
        <div class="page-header">
            <div class="page-header-content">
                <div class="page-title-section">
                    <div class="page-icon">
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <div class="page-title-text">
                        <h1>مواعيدي</h1>
                        <p>جميع المواعيد الطبية الخاصة بك</p>
                    </div>
                </div>
                <div class="page-actions">
                    <a href="@Url.Action("Dashboard", "Patient")" class="btn btn-secondary">
                        <i class="fas fa-arrow-right"></i>
                        <span>العودة</span>
                    </a>
                    <a href="@Url.Action("BookAppointment", "Patient")" class="btn btn-primary">
                        <i class="fas fa-plus"></i>
                        <span>حجز موعد جديد</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Filter Tabs -->
        <div class="appointments-section">
            <div style="display: flex; gap: 1rem; margin-bottom: 2rem; border-bottom: 2px solid #E0F2FE; padding-bottom: 1rem;">
                <a href="@Url.Action("MyAppointments", "Patient", new { status = "All" })"
                   class="btn @(currentStatus == "All" ? "btn-primary" : "btn-secondary")"
                   style="flex: 1; justify-content: center;">
                    <i class="fas fa-list"></i>
                    <span>الكل (@ViewBag.AllCount)</span>
                </a>
                <a href="@Url.Action("MyAppointments", "Patient", new { status = "Scheduled" })"
                   class="btn @(currentStatus == "Scheduled" ? "btn-primary" : "btn-secondary")"
                   style="flex: 1; justify-content: center;">
                    <i class="fas fa-clock"></i>
                    <span>مجدول (@ViewBag.ScheduledCount)</span>
                </a>
                <a href="@Url.Action("MyAppointments", "Patient", new { status = "Completed" })"
                   class="btn @(currentStatus == "Completed" ? "btn-primary" : "btn-secondary")"
                   style="flex: 1; justify-content: center;">
                    <i class="fas fa-check-circle"></i>
                    <span>مكتمل (@ViewBag.CompletedCount)</span>
                </a>
                <a href="@Url.Action("MyAppointments", "Patient", new { status = "Cancelled" })"
                   class="btn @(currentStatus == "Cancelled" ? "btn-primary" : "btn-secondary")"
                   style="flex: 1; justify-content: center;">
                    <i class="fas fa-times-circle"></i>
                    <span>ملغي (@ViewBag.CancelledCount)</span>
                </a>
            </div>

            <!-- Appointments List -->
            @if (Model != null && Model.Any())
            {
                <div style="display: grid; gap: 1.5rem;">
                    @foreach (var appointment in Model)
                    {
                        <div style="background: white; border-radius: 16px; padding: 2rem; border: 2px solid #E2E8F0; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.1); transition: all 0.3s ease;">
                            <div style="display: grid; grid-template-columns: auto 1fr auto; gap: 2rem; align-items: center;">
                                <!-- Doctor Avatar -->
                                <div style="width: 80px; height: 80px; background: var(--patient-gradient); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 2rem; font-weight: 800; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);">
                                    @if (!string.IsNullOrEmpty(appointment.Doctor?.User?.FullName))
                                    {
                                        var nameParts = appointment.Doctor.User.FullName.Split(' ');
                                        var initials = nameParts.Length >= 2
                                        ? nameParts[0].Substring(0, 1) + nameParts[1].Substring(0, 1)
                                        : nameParts[0].Substring(0, 1);
                                        <span>@initials</span>
                                    }
                                </div>

                                <!-- Appointment Info -->
                                <div>
                                    <h3 style="font-size: 1.5rem; font-weight: 800; color: #0F172A; margin: 0 0 0.5rem 0;">
                                        د. @appointment.Doctor?.User?.FullName
                                    </h3>
                                    <p style="color: var(--patient-primary); font-weight: 600; margin: 0 0 1rem 0;">
                                        <i class="fas fa-stethoscope"></i>
                                        @appointment.Doctor?.Specialization
                                    </p>

                                    <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                                        <div style="display: flex; align-items: center; gap: 0.5rem; color: #64748B;">
                                            <i class="fas fa-calendar" style="color: var(--patient-primary);"></i>
                                            <span>@appointment.AppointmentDate.ToString("yyyy-MM-dd")</span>
                                        </div>
                                        <div style="display: flex; align-items: center; gap: 0.5rem; color: #64748B;">
                                            <i class="fas fa-clock" style="color: var(--patient-primary);"></i>
                                            <span>@appointment.AppointmentDate.ToString("hh:mm tt")</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(appointment.Reason))
                                        {
                                            <div style="display: flex; align-items: center; gap: 0.5rem; color: #64748B;">
                                                <i class="fas fa-info-circle" style="color: var(--patient-primary);"></i>
                                                <span>@appointment.Reason</span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Status & Actions -->
                                <div style="text-align: left; display: flex; flex-direction: column; gap: 1rem;">
                                    @if (appointment.Status == "Scheduled")
                                    {
                                        <span class="status-badge status-scheduled">
                                            <i class="fas fa-clock"></i> مجدول
                                        </span>
                                    }
                                    else if (appointment.Status == "Completed")
                                    {
                                        <span class="status-badge status-completed">
                                            <i class="fas fa-check-circle"></i> مكتمل
                                        </span>
                                    }
                                    else if (appointment.Status == "Cancelled")
                                    {
                                        <span class="status-badge status-cancelled">
                                            <i class="fas fa-times-circle"></i> ملغي
                                        </span>
                                    }

                                    <a href="@Url.Action("AppointmentDetails", "Patient", new { id = appointment.AppointmentId })"
                                       class="btn btn-primary"
                                       style="padding: 0.75rem 1.5rem; font-size: 0.9rem;">
                                        <i class="fas fa-eye"></i>
                                        <span>عرض التفاصيل</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="fas fa-calendar-times"></i>
                    </div>
                    <h3>لا توجد مواعيد @(currentStatus == "All" ? "" : currentStatus == "Scheduled" ? "مجدولة" : currentStatus == "Completed" ? "مكتملة" : "ملغية")</h3>
                    <p>لم تقم بحجز أي موعد في هذه الفئة</p>
                    <a href="@Url.Action("BookAppointment", "Patient")" class="btn btn-primary">
                        <i class="fas fa-plus"></i>
                        <span>احجز موعداً جديداً</span>
                    </a>
                </div>
            }
        </div>
    </div>
</div>
